{
  "name": "ppx-pes-token",
  "version": "1.0.0",
  "description": "PES token, presale, and vesting contracts",
  "main": "hardhat.config.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 6284 --strictPort",
    "build": "vite build",
    "deploy:pages": "npm run build && wrangler pages deploy dist --project-name=ppx-pes-token --commit-dirty=true",
    "preview": "vite preview --host 127.0.0.1 --port 6285",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.js",
    "deploy:bsc-testnet:test": "hardhat run scripts/deploy-and-test-bsc-testnet.js --network bscTestnet",
    "deploy:presale-payment:test": "hardhat run scripts/deploy-presale-with-payment-test.js --network bscTestnet",
    "fund:presale": "hardhat run scripts/fund-presale.js",
    "grant:allocations": "hardhat run scripts/grant-allocations.js",
    "simulate:admin-batch": "node scripts/simulate-admin-batch-allocation.js",
    "configure:presale:schedule": "node scripts/configure-mainnet-presale-schedule.js",
    "schedule:auto-distribution": "hardhat run scripts/set-auto-distribution-schedule.js --network bsc",
    "resume:vesting": "node scripts/resume-vesting-no-catchup.js",
    "upgrade:presale": "hardhat run scripts/upgrade-mainnet-presale.js --network bsc",
    "enable:trading": "hardhat run scripts/enable-trading.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dappweb/ppx-pes-token.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/dappweb/ppx-pes-token/issues"
  },
  "homepage": "https://github.com/dappweb/ppx-pes-token#readme",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@openzeppelin/hardhat-upgrades": "^3.9.1",
    "@vitejs/plugin-react": "^5.1.2",
    "hardhat": "^2.28.6",
    "vite": "^7.2.7"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "@rainbow-me/rainbowkit": "^2.2.11",
    "@tanstack/react-query": "^5.100.9",
    "dotenv": "^17.2.3",
    "ethers": "^6.16.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "viem": "^2.48.11",
    "wagmi": "^2.19.5"
  },
  "overrides": {
    "axios": "^1.16.1",
    "lodash": "^4.18.1"
  }
}
